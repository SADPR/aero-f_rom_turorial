# -------------------------
# Editor / temp files
# -------------------------
*~
*.swp
*.swo

# -------------------------
# Compiled / binary artifacts
# -------------------------
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.opt

# -------------------------
# Preprocess-generated files
# -------------------------
# Mesh decomposition files generated by partnmesh/partdmesh
sources/*.dec.*
sources/*.top.dec.*

# Sower-generated split mesh and connectivity outputs
# (generated by preprocess.sh)
data/

# HROM preprocessed data directories (generated)
data.hrom.*/
data.hrom_ann.*/
data.hrom_gp.*/
data.hrom_rbf.*/

# -------------------------
# Simulation runtime outputs
# -------------------------
simulations/**/log/
simulations/**/results/
simulations/**/references/
simulations/**/postpro/
simulations/**/snapshots/

# Common generated artifacts from runs
simulations/**/*.out
simulations/**/*.exo

# -------------------------
# Offline/HROM generated model artifacts
# -------------------------
# Ignore generated nonlinearrom data products (state/gappy/reduced/etc.),
# but keep helper scripts in those folders tracked.
simulations/**/nonlinearrom/**
!simulations/**/nonlinearrom/**/
!simulations/**/nonlinearrom/**/*.sh
!simulations/**/nonlinearrom/**/*.py
!simulations/**/nonlinearrom/**/*.md

# Comparison plots used in README/tutorial
!simulations/postpro_compare/
!simulations/postpro_compare/**

# Local runtime directory generated by setup_xp2exo_runtime.sh
.xp2exo_runtime/

# Keep the portable xp2exo bundle for reproducible postprocessing
!xp2exo_bundle/
!xp2exo_bundle/xp2exo
!xp2exo_bundle/lib/
!xp2exo_bundle/lib/*.so
!xp2exo_bundle/lib/*.so.*
xp2exo_bundle.tgz

# Downloaded external reference material
reference/**
