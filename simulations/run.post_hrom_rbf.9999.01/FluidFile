under Problem {
  Type = UnsteadyNonlinearRomPostprocessing;
  Mode = Dimensional;
  Framework = BodyFitted;
}

under Input {
  GeometryPrefix = "../../data/OUTPUT";
  ReducedCoordinates = "../run.hrom_rbf.9999.01/postpro/ReducedCoords.out";
}

under NonlinearRomFileSystem {
  Prefix = "../run.offline_rbf.9999.01/";
  TopLevelDirectory = "nonlinearrom";
  under Files {
    StatePrefix = "state";
    GeneralManifoldRbfName = "../run.offline_rbf.9999.01/nonlinearrom/cluster0/";
  }
}

under NonlinearRomOnline {
  MaximumEnergy = 9.999e-1;
  UseGeneralManifold = True;
}

under Output {
  under Postpro {
    Frequency = 5;
    Prefix = "results/";
    LiftandDrag = "../postpro/LiftandDrag.out";
    Pressure = "Pressure.bin";
    Velocity = "Velocity.bin";
    Vorticity = "Vorticity.bin";
    CPUTiming = "../log/cputime.out";
  }
  under Restart {
    Frequency = 100;
    Prefix = "references/";
    Solution = "Solution.bin";
    RestartData = "Restart.data";
  }
  under Probes {
    Prefix = "postpro/";
    Pressure = "ProbePressure.out";
    Velocity = "ProbeVelocity.out";
    under Node1 {
      LocationX = 5.5;
      LocationY = 0.0;
      LocationZ = 0.0;
    }
  }
}

under BoundaryConditions {
  under Inlet {
    Type = External;
    Mach = 0.2;
    Alpha = 0.0;
    Beta = 0.0;
    Density = 1.0;
    Pressure = 17.8571428571;
  }
  under Wall {
    Type = Adiabatic;
    Integration = Full;
  }
}

under ReferenceState {  
  Length = 1.0;
}

under Equations {  
  Type = NavierStokes;   
  under FluidModel[0] {
    Fluid = PerfectGas;
    under GasModel {
      SpecificHeatRatio = 1.4;
      IdealGasConstant = 287.1;
    }
  }
  under ViscosityModel {
    Type = Constant;
    DynamicViscosity = 0.01;  // yields Re = 100
  }
  under TurbulenceClosure {
    Type = None;
  }
}

under Space {
  under NavierStokes {
    Flux = Roe;
    Reconstruction = Linear;
    AdvectiveOperator = FiniteVolume;
    Limiter = None;
    Dissipation = SecondOrder;
    Gradient = LeastSquares;
    Beta = 0.3333333333333333;
    Gamma = 0.0;
  }
  under Boundaries {
    Type = StegerWarming;
  }
}

under Time {
  MaxIts = 10000;
  MaxTime = 150;
  TimeStep = 0.1;
  Type = Implicit;
  under Implicit {
    Type = RungeKutta2;
  }
}

